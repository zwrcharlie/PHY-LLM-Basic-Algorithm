# Magnus 平台训练配置文件
# 使用方法: source magnus_config.env && ./magnus_train.sh

# ========================================
# 模型配置
# ========================================

# 模型缓存目录（集群共享存储，模型将持久化保存）
export MODEL_CACHE_DIR="/shared/models"

# 基础模型名称（HuggingFace Hub）
export MODEL_NAME="Qwen/Qwen2.5-1.5B-Instruct"

# ========================================
# 训练配置
# ========================================

# 批次大小（根据显存调整）
export BATCH_SIZE=4

# 训练轮数
export NUM_EPOCHS=3

# 学习率
export LEARNING_RATE="2e-4"

# 是否使用 4bit 量化（节省显存）
export USE_4BIT=false

# 训练数据文件
export TRAIN_FILE="train.json"
export VAL_FILE="val.json"

# 训练输出目录（容器内临时目录）
export OUTPUT_DIR="./output"

# ========================================
# 结果存储配置
# ========================================

# 最终模型存储路径（集群共享存储，持久化）
# 自动添加时间戳避免覆盖
export FINAL_MODEL_DIR="/shared/trained_models/qwen_integral_$(date +%Y%m%d_%H%M%S)"

# ========================================
# Magnus 平台配置（可选）
# ========================================

# 如果使用 Magnus File Custody 传入模型，设置此变量
# export MODEL_SECRET="magnus-secret:7919-calm-boat-fire"

# Magnus 工作目录（通常由平台自动设置）
# export MAGNUS_WORKSPACE="/magnus/workspace"
# export MAGNUS_ACTION="/magnus/workspace/.magnus_action"

# ========================================
# Apptainer 挂载配置（如需修改）
# ========================================

# 在 magnus_config.yaml 中配置额外挂载:
# cluster:
#   default_system_entry_command: |-
#     mounts=(
#       "/home:/home"
#       "/shared/models:/models"
#       "/shared/trained_models:/trained_models"
#     )
#     export APPTAINER_BIND=$(IFS=,; echo "${mounts[*]}")